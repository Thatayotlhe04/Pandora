# ── Supabase (hot store) ──────────────────────────────────────────────────
# Use the SERVICE ROLE key (server-side only — bypasses RLS). Never the anon key.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Upstash Redis (BullMQ queue) ──────────────────────────────────────────
# Use the rediss:// TLS URL from the Upstash console.
REDIS_URL=rediss://default:password@xxxx.upstash.io:6379

# ── Cloudflare R2 (cold store) ────────────────────────────────────────────
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=pandora-lake

# ── Service config ────────────────────────────────────────────────────────
PORT=8787
INGEST_MAX_BATCH=500
HMAC_MAX_SKEW_SEC=300
COMPACTION_INTERVAL_MS=60000
COMPACTION_BATCH=5000
LOG_LEVEL=info
